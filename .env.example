# Keycloak SSO (public PKCE client)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=your-realm-name
KEYCLOAK_CLIENT_ID=your-public-client-id

# Keycloak Admin (confidential client credentials)
KEYCLOAK_ADMIN_CLIENT_ID=your-backend-client-id
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...replace-with-real-key...

# App
APP_SECRET_KEY=generate-a-long-random-string-32-chars-minimum
APP_BASE_URL=http://localhost:8000
APP_PORT=8000
APP_DEBUG=false
